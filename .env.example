# Modifiable environment — copy to `.env` and edit. `.env` is gitignored; this
# template carries NO secrets, only placeholders and where to obtain each value.
#
# Agent tunables are namespaced by env prefix (e.g. PROVIDER_, ANALYST_) and are
# bounds-checked on load. Full catalogue: docs/configuration.md.
#
# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ REQUIRED MINIMUM — the system cannot do real work without these.          ║
# ╚══════════════════════════════════════════════════════════════════════════╝
#
# 1) Neo4j — the single primary store (ADR-0001). Acquire a free instance at
#    Neo4j Aura: https://console.neo4j.io  (or self-host).
NEO4J_URI=neo4j+s://<your-instance>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
# Set NEO4J_TEST_URI to run the live Neo4j integration test (else it skips):
NEO4J_TEST_URI=

# 2) Market-data feed (provider) — fundamentals + news. Free key:
#    https://finnhub.io/register  →  dashboard.
PROVIDER_FINNHUB_API_KEY=
# Macro/regime inputs (FRED). Free key: https://fredaccount.stlouisfed.org/apikeys
PROVIDER_FRED_API_KEY=

# 3) Operator LLM (Anthropic SDK default reads ANTHROPIC_API_KEY).
#    Key: https://console.anthropic.com  →  Settings → API Keys.
ANTHROPIC_API_KEY=
# Optional model override (default in OperatorSettings):
# OPERATOR_MODEL=claude-sonnet-4-6

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ OPTIONAL — data fallback, advisory ML, observability, future infra.       ║
# ╚══════════════════════════════════════════════════════════════════════════╝
#
# OHLCV note: Stooq (keyless) is anti-bot-blocked (DRIFT-009); for raw historical
# OHLCV in tests the probe harness reads price_cache from a Postgres instance.
# RAW DATA ONLY — never v1 derived data. Any Postgres works.
DATABASE_URL=

# FinBERT (advisory sentiment, forecaster — future P12). HuggingFace token:
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Azure — telemetry/log plane (ADR-0003) and the Service Bus comms bus (ADR-0005,
# P14). Service principal + resources from https://portal.azure.com .
# AZURE_SP_CLIENT_ID=
# AZURE_SP_CLIENT_SECRET=
# AZURE_SP_TENANT_ID=
# PROMETHEUS_REMOTE_WRITE_URL=
# SERVICEBUS_CONNECTION_STRING=        # P14 sprint 8 (inter-agent pub/sub)
# EVENTHUBS_CONNECTION_STRING=         # ADR-0003 (log plane)

# ── Example agent tunables (illustrative — each agent's land with it) ─────────
# PROVIDER_FINNHUB_BASE_URL=https://finnhub.io/api/v1
# ANALYST_RELATIVE_STRENGTH_WEIGHT=0.20
# PORTFOLIO_MANAGER_MAX_POSITION_PCT=0.05
# PORTFOLIO_MANAGER_MIN_REWARD_RISK_RATIO=1.5
#
# NOTE: a local `.env` may also carry inherited v1 parameters (CASH_BUFFER_PCT,
# MAX_POSITIONS, OPENAI_*, OLLAMA_*, PG*, …). v2 does not read those — its config
# is the agent-prefixed names above; the inherited keys are inert.
