# Copy to `.env` and fill in your secrets. `.env` is gitignored; this template
# carries NO secrets — only placeholders and where to obtain each value.
# Run scripts/test-api-keys.ps1 to verify all keys after filling.
#
# Agent tunables are namespaced by env prefix (e.g. PROVIDER_, ANALYST_) and are
# bounds-checked on load. Full catalogue: docs/configuration.md.
#
# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ REQUIRED MINIMUM — the system cannot do real work without these.          ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Active LLM provider ──────────────────────────────────────────────────────
# Selects which LLM backend the operator agent uses at startup.
# The runtime fallback mechanism may switch this dynamically (e.g. on quota
# exhaustion or error) — the in-flight value takes precedence over this file.
# Both providers must have valid keys below for fallback to work.
LLM_PROVIDER=openai  # openai | anthropic

# ── Anthropic (operator LLM) — REQUIRED ──────────────────────────────────────
# Key: https://console.anthropic.com → Settings → API Keys
# Verify: curl https://api.anthropic.com/v1/models -H "x-api-key: <key>" -H "anthropic-version: 2023-06-01"
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001    # override default in OperatorSettings

# ── OpenAI (alternative LLM) ─────────────────────────────────────────────────
# Key: https://platform.openai.com/api-keys
# Verify: curl https://api.openai.com/v1/models -H "Authorization: Bearer <key>"
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=high                 # low | medium | high

# ── Market-data feeds (provider agent) — REQUIRED for live runs ──────────────
# Finnhub — fundamentals + news. Key: https://finnhub.io/register
# Verify: curl "https://finnhub.io/api/v1/quote?symbol=AAPL&token=<key>"
PROVIDER_FINNHUB_API_KEY=
# FRED — macro/regime inputs. Key: https://fredaccount.stlouisfed.org/apikeys
# Verify: curl "https://api.stlouisfed.org/fred/series?series_id=GDP&api_key=<key>&file_type=json"
PROVIDER_FRED_API_KEY=
# FinancialModelingPrep (supplemental). Key: https://financialmodelingprep.com/developer/docs
# Verify: curl "https://financialmodelingprep.com/stable/search-symbol?query=AAPL&apikey=<key>"  (/stable/ endpoints, not /api/v3/)
FNP_API_KEY=
# Massive. Key: https://console.massiveapi.com
MASSIVE_API_KEY=

# ── Neo4j Aura — REQUIRED; system cannot start without a valid URI ────────────
# Acquire a free instance at https://console.neo4j.io (or self-host).
# Code reads NEO4J_USER (not NEO4J_USERNAME).
NEO4J_URI=neo4j+s://<your-instance>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
# Default database on Aura is "neo4j"; informational until GraphSettings adds a db field.
NEO4J_DATABASE=neo4j
# Set to run the live integration test (creates/deletes GraphStoreTest nodes; else skips):
NEO4J_TEST_URI=

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ OPTIONAL — data fallback, advisory ML, observability, future infra.       ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── PostgreSQL (raw OHLCV fallback — probe harness only) ─────────────────────
# RAW DATA ONLY — never v1 derived data (DRIFT-009). Any Postgres works.
# Stooq (keyless) is anti-bot-blocked; probes read OHLCV from price_cache here.
DATABASE_URL=                                # postgresql://user:pass@host:5432/db?sslmode=require
# PGHOST=
# PGUSER=
# PGPORT=5432
# PGDATABASE=
# PGPASSWORD=
# TEST_DATABASE_URL=                         # same host, separate _test database

# ── Training / FinBERT (advisory sentiment, forecaster — future P12) ─────────
# Key: https://huggingface.co/settings/tokens
# Verify: curl https://huggingface.co/api/whoami-v2 -H "Authorization: Bearer <token>"
HF_TOKEN=

# ── Azure observability (ADR-0003) ──────────────────────────────────────────
# Resources from https://portal.azure.com
# AZURE_OBSERVABILITY_ENABLED=false          # true | false
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=                       # rotate every 90 days
# AZURE_MONITOR_CONNECTION_STRING=           # Application Insights → Connection String tab
# AZURE_LOGS_INGESTION_ENDPOINT=             # Data Collection Endpoint URL
# AZURE_LOGS_DCR_IMMUTABLE_ID=               # Data Collection Rule immutable ID (dcr-…)
# AZURE_LOGS_STREAM_EVENTS=Custom-ObservabilityEvents
# AZURE_LOGS_STREAM_HEALTH=Custom-HealthSnapshots
# AZURE_LOGS_STREAM_INCIDENTS=Custom-Incidents

# ── Azure Prometheus → Azure Monitor ─────────────────────────────────────────
# Service principal set by infra/setup-prometheus-auth.ps1
# AZURE_SP_CLIENT_ID=
# AZURE_SP_CLIENT_SECRET=                    # rotate every 90 days
# AZURE_SP_TENANT_ID=
# PROMETHEUS_REMOTE_WRITE_URL=               # https://<workspace>.prometheus.monitor.azure.com/api/v1/write

# ── Future / optional ─────────────────────────────────────────────────────────
# SERVICEBUS_CONNECTION_STRING=              # P14 sprint 8 (inter-agent pub/sub)
# EVENTHUBS_CONNECTION_STRING=               # ADR-0003 (log plane)

# ── Example agent tunables (illustrative — each agent owns its own) ───────────
# PROVIDER_FINNHUB_BASE_URL=https://finnhub.io/api/v1
# ANALYST_RELATIVE_STRENGTH_WEIGHT=0.20
# PORTFOLIO_MANAGER_MAX_POSITION_PCT=0.05    # float 0.01–0.20
# PORTFOLIO_MANAGER_MIN_REWARD_RISK_RATIO=1.5
#
# NOTE: a local `.env` may carry inherited v1 parameters (CASH_BUFFER_PCT,
# MAX_POSITIONS, OPENAI_*, OLLAMA_*, PG*, …). v2 does not read those — its config
# is the agent-prefixed names above; the inherited keys are inert.
