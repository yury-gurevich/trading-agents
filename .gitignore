# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Environments
.venv/
.env
.env.*
# ...but the template (no secrets) is tracked.
!.env.example

# Trained model artifacts (produced offline; not committed)
/models/*.txt
/models/*.bin
/models/*.lgb

# Local data stores
*.sqlite
*.db
/neo4j-data/
/data/
.codeql-db/
.tools/
# CodeQL generated scan outputs (the tool — queries + scripts — is committed; runs are not)
codeql/**/*.sarif
codeql/python-security/reports/*/latest/
codeql/python-security/reports/*/archive/
codeql/python-security/reports/AgentCrossImport-report.md

# OS / editor
.DS_Store
.idea/
.vscode/

# Claude Code — transient agent worktrees
.claude/worktrees/

# Azure deploy outputs (endpoint URLs, not secrets — but no need to track)
# tools/* excludes binaries/executables; tools/scripts/ is excepted below
tools/*
!tools/scripts/
!tools/scripts/**
infra/.azure-outputs
infra/prometheus/prometheus.generated.yml
infra/prometheus/prometheus.local.yml
infra/*.local.json
infra/*.local.env
desktop.ini

infra/*.local.py
