{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Azure Monitor (Prometheus)",
      "description": "Azure Monitor workspace Prometheus endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "uid": "trading-agents-main",
  "title": "trading-agents — System Health",
  "description": "Per-agent throughput, latency, and fault rate from the kernel metrics adapter.",
  "tags": ["trading-agents", "observability"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request rate (req/min)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqpm", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{ "expr": "sum(rate(trading_agents_kernel_requests_total[5m])) * 60", "legendFormat": "req/min" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate (%)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(rate(trading_agents_kernel_requests_total{outcome=\"error\"}[5m])) / sum(rate(trading_agents_kernel_requests_total[5m])) * 100",
        "legendFormat": "error %"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Fault rate (faults/min)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [{ "expr": "sum(rate(trading_agents_kernel_faults_total[5m])) * 60", "legendFormat": "faults/min" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "P99 latency (ms)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(trading_agents_kernel_request_latency_seconds_bucket[5m])) by (le)) * 1000",
        "legendFormat": "p99 ms"
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests by agent",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [{
        "expr": "sum(rate(trading_agents_kernel_requests_total[5m])) by (agent)",
        "legendFormat": "{{agent}}"
      }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Errors by agent",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } } },
      "targets": [{
        "expr": "sum(rate(trading_agents_kernel_requests_total{outcome=\"error\"}[5m])) by (agent)",
        "legendFormat": "{{agent}}"
      }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "P99 latency by agent (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(trading_agents_kernel_request_latency_seconds_bucket[5m])) by (agent, le)) * 1000",
        "legendFormat": "p99 {{agent}}"
      }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "P50 latency by agent (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [{
        "expr": "histogram_quantile(0.50, sum(rate(trading_agents_kernel_request_latency_seconds_bucket[5m])) by (agent, le)) * 1000",
        "legendFormat": "p50 {{agent}}"
      }]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Faults by severity",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{
        "expr": "sum(rate(trading_agents_kernel_faults_total[5m])) by (severity)",
        "legendFormat": "{{severity}}"
      }]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Faults by source agent",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{
        "expr": "sum(rate(trading_agents_kernel_faults_total[5m])) by (source_agent)",
        "legendFormat": "{{source_agent}}"
      }]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
